      "id": "8aad70dc-e93d-4169-a82f-6d6e29e42ab1",
      "name": "Research Agent"
    },
    {
      "parameters": {
        "jsCode": "const raw = $json.data || $json.response || \"\";\n\n// split each streamed JSON line\nconst lines = raw.split(\"\\n\").filter(l => l.trim() !== \"\");\n\nlet text = \"\";\n\nfor (const line of lines) {\n  try {\n    const obj = JSON.parse(line);\n    if (obj.response) {\n      text += obj.response;\n    }\n  } catch (err) {}\n}\n\nreturn [\n  {\n    json: {\n      final_report: text\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
